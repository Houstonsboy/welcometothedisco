rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: anyone can read; only owner can write their doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Versus: read for listing; create for authenticated; update only to add 'type' (backfill) or by author
    match /versus/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Allow update if: (1) only adding/changing 'type' field (one-time backfill), or (2) user is the document author
      allow update: if request.auth != null
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['type'])
          || request.auth.uid == resource.data.Author
          || request.auth.uid == resource.data.authorID
        );
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.Author || request.auth.uid == resource.data.authorID);
    }
  }
}
