rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: anyone can read; only owner can write their doc
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;

      // Follow notifications subcollection
      // Doc ID = followerUID so one follower can only ever create one doc per recipient.
      match /notifications/{notifId} {
        // Only the recipient reads their own notifications
        allow read: if request.auth != null && request.auth.uid == userId;

        // Follow: sender is the follower — must match followerID.
        // Invite: sender is author — must match authorID; written under recipient userId.
        allow create: if request.auth != null && (
          request.resource.data.type == 'follow'
            && request.resource.data.followerID == request.auth.uid
          || request.resource.data.type == 'invite'
            && request.resource.data.authorID == request.auth.uid
            && userId != request.auth.uid
        );

        // Only the recipient can update — restricted to marking as read only
        allow update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      }
    }

    // Versus: read for listing; create for authenticated; update only to add 'type' (backfill) or by author
    match /versus/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      // Allow update if: (1) only adding/changing 'type' field (one-time backfill), or (2) user is the document author
      allow update: if request.auth != null
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['type'])
          || request.auth.uid == resource.data.Author
          || request.auth.uid == resource.data.authorID
        );
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.Author || request.auth.uid == resource.data.authorID);
    }
  }
}
